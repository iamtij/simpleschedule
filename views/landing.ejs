<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>isked – Scheduling Made Easy</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Libre+Baskerville:ital,wght@0,400;0,700;1,400&family=Plus+Jakarta+Sans:ital,wght@0,400;0,500;0,600;0,700;1,400&display=swap" rel="stylesheet">
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    fontFamily: {
                        serif: ['"Libre Baskerville"', 'Georgia', 'serif'],
                        sans: ['"Plus Jakarta Sans"', 'system-ui', 'sans-serif'],
                    },
                    colors: {
                        brand: {
                            50: '#f5f3ff',
                            100: '#ede9fe',
                            200: '#ddd6fe',
                            300: '#c4b5fd',
                            400: '#a78bfa',
                            500: '#8b5cf6',
                            600: '#7c3aed',
                            700: '#6d28d9',
                            800: '#5b21b6',
                            900: '#4c1d95',
                        },
                    },
                    animation: {
                        'float-slow': 'float-y 5s ease-in-out infinite',
                        'float-delayed': 'float-y 5s ease-in-out 1.2s infinite',
                    },
                    keyframes: {
                        'float-y': {
                            '0%, 100%': { transform: 'translateY(0)' },
                            '50%': { transform: 'translateY(-10px)' },
                        },
                    },
                },
            },
        };
    </script>
    <script src="https://unpkg.com/feather-icons"></script>
    <link rel="icon" type="image/png" sizes="96x96" href="/favicon-96x96.png">
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png">
    <link rel="icon" type="image/x-icon" href="/favicon.ico">
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png">
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png">
    <link rel="icon" type="image/png" sizes="192x192" href="/android-chrome-192x192.png">
    <link rel="icon" type="image/png" sizes="512x512" href="/android-chrome-512x512.png">
    <meta name="theme-color" content="#7c3aed">
    <style>
        .hero-mesh {
            background-color: #faf8ff;
            background-image:
                radial-gradient(ellipse 80% 60% at 20% 10%, rgba(167, 139, 250, 0.28), transparent 55%),
                radial-gradient(ellipse 70% 50% at 85% 30%, rgba(139, 92, 246, 0.18), transparent 50%),
                radial-gradient(ellipse 60% 45% at 50% 95%, rgba(192, 132, 252, 0.12), transparent 45%);
        }
        details.mobile-nav > summary {
            list-style: none;
        }
        details.mobile-nav > summary::-webkit-details-marker {
            display: none;
        }
        .reveal {
            opacity: 0;
            transform: translateY(1.25rem);
            transition: opacity 0.6s ease, transform 0.6s ease;
        }
        .reveal.reveal-visible {
            opacity: 1;
            transform: translateY(0);
        }
        @media (prefers-reduced-motion: reduce) {
            .reveal {
                opacity: 1;
                transform: none;
                transition: none;
            }
            .animate-float-slow,
            .animate-float-delayed {
                animation: none !important;
            }
        }
    </style>
</head>
<body class="bg-white text-gray-900 font-sans antialiased">
    <!-- Navigation -->
    <header class="fixed top-0 inset-x-0 z-50 border-b border-violet-100/80 bg-white/80 backdrop-blur-md">
        <nav class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="flex h-14 sm:h-16 items-center justify-between gap-4">
                <a href="/" class="text-xl font-bold tracking-tight text-brand-700 shrink-0">isked</a>
                <div class="hidden md:flex items-center gap-6 lg:gap-8">
                    <a href="#features" class="text-sm font-medium text-gray-600 hover:text-gray-900 transition-colors">Features</a>
                    <a href="#how-it-works" class="text-sm font-medium text-gray-600 hover:text-gray-900 transition-colors">How it works</a>
                    <a href="#pricing" class="text-sm font-medium text-gray-600 hover:text-gray-900 transition-colors">Pricing</a>
                </div>
                <div class="flex items-center gap-2 sm:gap-3">
                    <a href="/auth/login" class="hidden md:inline-flex text-sm font-semibold text-gray-700 hover:text-gray-900 px-3 py-2 rounded-lg hover:bg-violet-50 transition-colors">
                        Log in
                    </a>
                    <a href="/auth/register" class="hidden md:inline-flex items-center justify-center rounded-lg bg-brand-600 px-4 py-2 text-sm font-semibold text-white shadow-sm hover:bg-brand-700 transition-colors">
                        Get started
                    </a>
                    <details class="mobile-nav md:hidden relative">
                        <summary class="flex cursor-pointer items-center justify-center rounded-lg border border-violet-200 bg-white p-2 text-gray-700 hover:bg-violet-50 transition-colors" aria-label="Open menu">
                            <i data-feather="menu" class="h-5 w-5"></i>
                        </summary>
                        <div class="absolute right-0 top-full z-50 mt-2 w-52 rounded-xl border border-violet-100 bg-white p-2 shadow-xl">
                            <a href="#features" class="block rounded-lg px-3 py-2.5 text-sm font-medium text-gray-700 hover:bg-violet-50">Features</a>
                            <a href="#how-it-works" class="block rounded-lg px-3 py-2.5 text-sm font-medium text-gray-700 hover:bg-violet-50">How it works</a>
                            <a href="#pricing" class="block rounded-lg px-3 py-2.5 text-sm font-medium text-gray-700 hover:bg-violet-50">Pricing</a>
                            <hr class="my-2 border-violet-100">
                            <a href="/auth/login" class="block rounded-lg px-3 py-2.5 text-sm font-semibold text-gray-900 hover:bg-violet-50">Log in</a>
                            <a href="/auth/register" class="mt-1 block rounded-lg bg-brand-600 px-3 py-2.5 text-center text-sm font-semibold text-white hover:bg-brand-700">Get started</a>
                        </div>
                    </details>
                </div>
            </div>
        </nav>
    </header>

    <!-- Hero -->
    <section class="hero-mesh relative pt-24 pb-14 sm:pt-28 sm:pb-20 lg:pt-32 lg:pb-28 overflow-hidden">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="grid lg:grid-cols-2 gap-10 lg:gap-12 xl:gap-16 items-center">
                <div class="text-center lg:text-left max-w-xl mx-auto lg:mx-0">
                    <p class="inline-flex items-center gap-2 rounded-full border border-violet-200 bg-white/90 px-3 py-1 text-xs sm:text-sm font-semibold text-brand-700 shadow-sm mb-5">
                        <span class="inline-block h-1.5 w-1.5 rounded-full bg-emerald-500 animate-pulse"></span>
                        Scheduling without the back-and-forth
                    </p>
                    <h1 class="font-serif text-[2rem] leading-[1.15] sm:text-4xl md:text-5xl lg:text-[2.75rem] xl:text-6xl text-gray-900">
                        <span class="italic font-normal block mb-1">Share your link.</span>
                        <span class="font-sans font-bold not-italic tracking-tight block text-gray-950">They pick a time. You stay in control.</span>
                    </h1>
                    <p class="mt-5 sm:mt-6 text-base sm:text-lg text-gray-600 leading-relaxed">
                        Let others book your time with ease. isked keeps availability, buffers, and client context in one calm workflow — no endless email threads.
                    </p>
                    <div class="mt-8 flex flex-col sm:flex-row sm:flex-wrap gap-3 justify-center lg:justify-start">
                        <a href="/auth/register" class="inline-flex items-center justify-center rounded-xl bg-brand-600 px-6 py-3.5 text-base font-semibold text-white shadow-lg shadow-brand-600/25 hover:bg-brand-700 transition-colors w-full sm:w-auto">
                            Create your booking link
                        </a>
                        <a href="#how-it-works" class="inline-flex items-center justify-center rounded-xl border-2 border-violet-200 bg-white px-6 py-3.5 text-base font-semibold text-gray-800 hover:border-brand-400 hover:bg-violet-50/80 transition-colors w-full sm:w-auto">
                            See how it works
                        </a>
                    </div>
                    <p class="mt-4 text-center lg:text-left text-sm text-gray-500">No credit card required to start.</p>
                    <div class="mt-6 flex flex-wrap gap-2 justify-center lg:justify-start lg:hidden">
                        <span class="inline-flex items-center gap-1.5 rounded-lg bg-white/95 border border-emerald-100 px-3 py-1.5 text-xs font-medium text-emerald-800 shadow-sm">
                            <i data-feather="check-circle" class="w-3.5 h-3.5 text-emerald-500"></i> Meeting booked
                        </span>
                        <span class="inline-flex items-center gap-1.5 rounded-lg bg-white/95 border border-violet-100 px-3 py-1.5 text-xs font-medium text-brand-800 shadow-sm">
                            <i data-feather="trending-up" class="w-3.5 h-3.5 text-brand-600"></i> Stay on top of your week
                        </span>
                    </div>
                    <p class="mt-8 rounded-xl border border-violet-100 bg-white/90 px-4 py-3 text-xs sm:text-sm text-gray-600 shadow-sm inline-block max-w-full">
                        Your booking link:
                        <span class="font-mono font-semibold text-brand-700 break-all">isked.app/booking/yourname</span>
                    </p>
                </div>

                <div class="relative mx-auto w-full max-w-md lg:max-w-none">
                    <!-- Floating cards (desktop) -->
                    <div class="hidden md:block absolute -left-4 top-8 z-10 animate-float-slow">
                        <div class="flex items-center gap-3 rounded-2xl border border-emerald-100 bg-white px-4 py-3 shadow-xl shadow-gray-900/10">
                            <span class="flex h-10 w-10 items-center justify-center rounded-full bg-emerald-50 text-emerald-600">
                                <i data-feather="check" class="w-5 h-5"></i>
                            </span>
                            <div>
                                <p class="text-xs font-medium text-gray-500">Just now</p>
                                <p class="text-sm font-semibold text-gray-900">Meeting booked</p>
                            </div>
                        </div>
                    </div>
                    <div class="hidden md:block absolute -right-2 lg:right-4 top-1/3 z-10 animate-float-delayed">
                        <div class="rounded-2xl border border-violet-100 bg-white px-4 py-3 shadow-xl shadow-gray-900/10">
                            <p class="text-2xl font-bold text-brand-700 tracking-tight">24</p>
                            <p class="text-xs font-medium text-gray-600">meetings this week</p>
                        </div>
                    </div>

                    <!-- Scheduling UI mock -->
                    <div class="relative rounded-2xl border border-violet-100 bg-white p-4 sm:p-5 shadow-2xl shadow-brand-900/10 ring-1 ring-black/5">
                        <div class="flex items-center justify-between border-b border-gray-100 pb-4 mb-4">
                            <div>
                                <p class="text-xs font-semibold uppercase tracking-wider text-brand-600">Preview</p>
                                <p class="text-sm font-bold text-gray-900">Book with Jordan</p>
                            </div>
                            <div class="flex gap-1">
                                <span class="h-2 w-2 rounded-full bg-red-400"></span>
                                <span class="h-2 w-2 rounded-full bg-amber-400"></span>
                                <span class="h-2 w-2 rounded-full bg-emerald-400"></span>
                            </div>
                        </div>
                        <div class="grid grid-cols-7 gap-1 text-center text-[10px] sm:text-xs font-medium text-gray-400 mb-2">
                            <span>Mo</span><span>Tu</span><span>We</span><span>Th</span><span>Fr</span><span>Sa</span><span>Su</span>
                        </div>
                        <div class="grid grid-cols-7 gap-1 mb-4">
                            <% for (let d = 1; d <= 7; d++) { %>
                            <button type="button" class="aspect-square rounded-lg text-xs font-semibold <%= d === 3 ? 'bg-brand-600 text-white shadow-md' : 'bg-gray-50 text-gray-600 hover:bg-violet-50' %>"><%= 10 + d %></button>
                            <% } %>
                        </div>
                        <p class="text-xs font-semibold text-gray-500 mb-2">Available slots</p>
                        <div class="grid grid-cols-2 sm:grid-cols-3 gap-2">
                            <span class="rounded-lg border border-brand-200 bg-brand-50 px-2 py-2 text-center text-xs font-semibold text-brand-800">9:00 AM</span>
                            <span class="rounded-lg border border-gray-100 bg-gray-50 px-2 py-2 text-center text-xs font-medium text-gray-500">9:30 AM</span>
                            <span class="rounded-lg border border-brand-200 bg-brand-50 px-2 py-2 text-center text-xs font-semibold text-brand-800">10:00 AM</span>
                            <span class="rounded-lg border border-gray-100 bg-gray-50 px-2 py-2 text-center text-xs font-medium text-gray-500">10:30 AM</span>
                            <span class="rounded-lg border border-brand-200 bg-brand-50 px-2 py-2 text-center text-xs font-semibold text-brand-800">2:00 PM</span>
                            <span class="rounded-lg border border-gray-100 bg-gray-50 px-2 py-2 text-center text-xs font-medium text-gray-500">2:30 PM</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Features -->
    <section id="features" class="scroll-mt-24 py-16 sm:py-20 px-4 sm:px-6 lg:px-8 bg-gradient-to-b from-white via-brand-50/30 to-white">
        <div class="max-w-7xl mx-auto">
            <div class="text-center max-w-2xl mx-auto mb-12 sm:mb-16 reveal">
                <h2 class="font-serif text-3xl sm:text-4xl font-bold text-gray-900 italic">Built for busy calendars</h2>
                <p class="mt-4 text-base sm:text-lg text-gray-600">Everything you need to accept bookings confidently — from buffers to CRM exports.</p>
            </div>
            <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5 sm:gap-6 lg:gap-8">
                <% const feats = [
                    { icon: 'calendar', title: 'Smart scheduling', desc: 'Custom availability, multiple windows per day, and date-specific overrides when your routine changes.' },
                    { icon: 'link', title: 'Share-ready links', desc: 'One link (or several durations) so guests self-serve a time that fits — no coordination ping-pong.' },
                    { icon: 'coffee', title: 'Buffer times', desc: 'Breathing room between meetings so you are never sprinting from call to call.' },
                    { icon: 'users', title: 'Built-in CRM', desc: 'Keep client context and meeting history where you already work — fewer tabs, fewer gaps.' },
                    { icon: 'bell', title: 'Notifications that help', desc: 'Stay ahead of the day with clear booking signals so nothing slips through the cracks.' },
                    { icon: 'file-text', title: 'Exports & trust', desc: 'Google Sheets export for your records plus thoughtful defaults so data stays yours.' },
                ]; %>
                <% feats.forEach((f, i) => { %>
                <article class="group reveal rounded-2xl border border-violet-100 bg-white/90 p-6 sm:p-8 shadow-sm hover:shadow-xl hover:border-brand-200/80 transition-all duration-300" style="transition-delay: <%= i * 40 %>ms">
                    <div class="flex h-12 w-12 items-center justify-center rounded-xl bg-brand-50 text-brand-600 group-hover:bg-brand-600 group-hover:text-white transition-colors duration-300">
                        <i data-feather="<%= f.icon %>" class="w-6 h-6"></i>
                    </div>
                    <h3 class="mt-5 text-lg sm:text-xl font-bold text-gray-900"><%= f.title %></h3>
                    <p class="mt-2 text-sm sm:text-base text-gray-600 leading-relaxed"><%= f.desc %></p>
                </article>
                <% }); %>
            </div>
            <div class="mt-14 sm:mt-16 max-w-lg mx-auto text-center reveal border-t border-violet-100 pt-12">
                <p class="text-base sm:text-lg font-semibold text-gray-900">Put these tools to work on your calendar today.</p>
                <p class="mt-2 text-sm text-gray-600">Free to start — your booking link goes live in minutes.</p>
                <div class="mt-6 flex flex-col sm:flex-row gap-3 justify-center items-stretch">
                    <a href="/auth/register" class="inline-flex justify-center items-center rounded-xl bg-brand-600 px-6 py-3.5 text-base font-semibold text-white shadow-lg shadow-brand-600/20 hover:bg-brand-700 transition-colors">Get started free</a>
                    <a href="#pricing" class="inline-flex justify-center items-center rounded-xl border-2 border-violet-200 bg-white px-6 py-3.5 text-base font-semibold text-gray-800 hover:border-brand-400 hover:bg-violet-50 transition-colors">See plans</a>
                </div>
            </div>
        </div>
    </section>

    <!-- How it works -->
    <section id="how-it-works" class="scroll-mt-24 py-16 sm:py-20 px-4 sm:px-6 lg:px-8 bg-white">
        <div class="max-w-7xl mx-auto">
            <div class="text-center max-w-2xl mx-auto mb-12 sm:mb-16 reveal">
                <h2 class="font-serif text-3xl sm:text-4xl font-bold text-gray-900 italic">How it works</h2>
                <p class="mt-4 text-base sm:text-lg text-gray-600">Three steps from chaos to a link your clients actually use.</p>
            </div>
            <div class="grid md:grid-cols-3 gap-8 lg:gap-10">
                <% const steps = [
                    { n: '01', title: 'Set your availability', desc: 'Define when you take meetings, buffers, and exceptions for special dates.' },
                    { n: '02', title: 'Share your booking link', desc: 'Drop it in email, bios, or invoices — guests pick a slot without asking “what time works?”' },
                    { n: '03', title: 'Show up prepared', desc: 'Bookings land with context in your CRM so every conversation picks up where it left off.' },
                ]; %>
                <% steps.forEach((s, i) => { %>
                <div class="relative reveal text-center md:text-left">
                    <% if (i < steps.length - 1) { %>
                    <div class="hidden md:block absolute top-10 left-[60%] w-[80%] h-px bg-gradient-to-r from-brand-200 to-transparent pointer-events-none" aria-hidden="true"></div>
                    <% } %>
                    <span class="inline-flex h-12 w-12 items-center justify-center rounded-full bg-brand-600 text-sm font-bold text-white shadow-lg shadow-brand-600/30"><%= s.n %></span>
                    <h3 class="mt-5 text-xl font-bold text-gray-900"><%= s.title %></h3>
                    <p class="mt-2 text-gray-600 leading-relaxed"><%= s.desc %></p>
                </div>
                <% }); %>
            </div>
            <div class="mt-14 sm:mt-16 max-w-lg mx-auto text-center reveal border-t border-gray-100 pt-12">
                <p class="text-base sm:text-lg font-semibold text-gray-900">Your booking link is only a few minutes away.</p>
                <p class="mt-2 text-sm text-gray-600">Sign up, set your windows, and share — we handle the rest.</p>
                <a href="/auth/register" class="mt-6 inline-flex justify-center items-center rounded-xl bg-brand-600 px-6 py-3.5 text-base font-semibold text-white shadow-lg shadow-brand-600/20 hover:bg-brand-700 transition-colors w-full sm:w-auto">Sign up free</a>
            </div>
        </div>
    </section>

    <!-- Stop the Scheduling Chaos -->
    <section class="py-16 sm:py-20 px-4 sm:px-6 lg:px-8 bg-gradient-to-b from-brand-50/40 to-white">
        <div class="max-w-6xl mx-auto reveal">
            <div class="rounded-3xl border border-violet-100 bg-white p-8 sm:p-12 lg:p-16 shadow-xl shadow-brand-900/5">
                <div class="max-w-3xl mx-auto text-center mb-10 sm:mb-12">
                    <h2 class="font-serif text-2xl sm:text-3xl lg:text-4xl font-bold text-gray-900 italic">Stop the scheduling chaos</h2>
                    <p class="mt-4 text-base sm:text-lg text-gray-600">Tired of endless back-and-forth, double bookings, or scattered client notes? Here is how isked helps.</p>
                </div>
                <div class="grid sm:grid-cols-2 gap-8 sm:gap-10 text-left">
                    <div class="flex gap-4">
                        <div class="flex h-11 w-11 shrink-0 items-center justify-center rounded-xl bg-red-50 text-red-500">
                            <i data-feather="mail" class="w-5 h-5"></i>
                        </div>
                        <div>
                            <p class="font-bold text-gray-900">No more email ping-pong</p>
                            <p class="mt-1 text-sm sm:text-base text-gray-600 leading-relaxed">Share your link once; clients book instantly.</p>
                        </div>
                    </div>
                    <div class="flex gap-4">
                        <div class="flex h-11 w-11 shrink-0 items-center justify-center rounded-xl bg-red-50 text-red-500">
                            <i data-feather="calendar" class="w-5 h-5"></i>
                        </div>
                        <div>
                            <p class="font-bold text-gray-900">Fewer double-booking surprises</p>
                            <p class="mt-1 text-sm sm:text-base text-gray-600 leading-relaxed">Availability and buffers keep your calendar honest.</p>
                        </div>
                    </div>
                    <div class="flex gap-4">
                        <div class="flex h-11 w-11 shrink-0 items-center justify-center rounded-xl bg-red-50 text-red-500">
                            <i data-feather="user-check" class="w-5 h-5"></i>
                        </div>
                        <div>
                            <p class="font-bold text-gray-900">Keep track of every client</p>
                            <p class="mt-1 text-sm sm:text-base text-gray-600 leading-relaxed">CRM-friendly history so context does not vanish after the call.</p>
                        </div>
                    </div>
                    <div class="flex gap-4">
                        <div class="flex h-11 w-11 shrink-0 items-center justify-center rounded-xl bg-red-50 text-red-500">
                            <i data-feather="clock" class="w-5 h-5"></i>
                        </div>
                        <div>
                            <p class="font-bold text-gray-900">Protect your time</p>
                            <p class="mt-1 text-sm sm:text-base text-gray-600 leading-relaxed">Boundaries between meetings — so your day breathes.</p>
                        </div>
                    </div>
                </div>
                <div class="mt-12 sm:mt-14 pt-10 border-t border-violet-100 text-center reveal">
                    <p class="text-base sm:text-lg font-semibold text-gray-900">Stop losing hours to email ping-pong.</p>
                    <p class="mt-2 text-sm text-gray-600">Let clients book themselves while you keep control of your calendar.</p>
                    <div class="mt-6 flex flex-col sm:flex-row gap-3 justify-center items-stretch">
                        <a href="/auth/register" class="inline-flex justify-center items-center rounded-xl bg-brand-600 px-6 py-3.5 text-base font-semibold text-white shadow-lg shadow-brand-600/20 hover:bg-brand-700 transition-colors">Get started free</a>
                        <a href="#pricing" class="inline-flex justify-center items-center rounded-xl border-2 border-violet-200 bg-white px-6 py-3.5 text-base font-semibold text-gray-800 hover:border-brand-400 hover:bg-violet-50 transition-colors">View pricing</a>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Testimonials -->
    <section class="py-16 sm:py-20 px-4 sm:px-6 lg:px-8 bg-white">
        <div class="max-w-7xl mx-auto">
            <div class="text-center max-w-2xl mx-auto mb-12 sm:mb-16 reveal">
                <h2 class="font-serif text-3xl sm:text-4xl font-bold text-gray-900 italic">What our users say</h2>
                <p class="mt-4 text-base sm:text-lg text-gray-600">Professionals who needed calmer scheduling.</p>
            </div>
            <% const starSvg = '<svg class="w-4 h-4 text-amber-400 shrink-0" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>'; %>
